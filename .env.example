GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
WHISPER_MODEL=base
MAX_PARALLEL_CLIPS=3
SILENCE_THRESHOLD_DB=-35
SILENCE_MIN_DURATION=0.8
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
PREFER_YOUTUBE_TRANSCRIPTS=true
CAPTION_ANIMATE=true
YTDLP_RETRY_ATTEMPTS=6
YTDLP_RETRY_BASE_DELAY_MS=1500
YTDLP_USE_IPV4=true
# Optional comma-separated proxies for blocked environments
# YTDLP_PROXY_URLS=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
